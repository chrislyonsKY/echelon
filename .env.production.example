# Echelon production environment template
# Copy to .env on the production host and replace every placeholder.
# Do not commit real production secrets.

# Application
SECRET_KEY=REPLACE_ME_RUN_python3_c_secrets_token_hex_32
DEBUG=false
ALLOWED_ORIGINS=["https://echelon-geoint.org","https://www.echelon-geoint.org"]

# Database / Redis — REPLACE ALL PASSWORDS before starting
POSTGRES_PASSWORD=REPLACE_ME_RUN_python3_c_secrets_token_hex_16
DATABASE_URL=postgresql+asyncpg://echelon:${POSTGRES_PASSWORD}@db:5432/echelon
REDIS_PASSWORD=REPLACE_ME_RUN_python3_c_secrets_token_hex_16
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Data providers
GFW_API_TOKEN=
NEWSDATA_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=
FIRMS_MAP_KEY=
AISSTREAM_API_KEY=
YOUTUBE_API_KEY=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com

# Encryption
BYOK_ENCRYPTION_KEY=

# Flower (Celery monitoring — internal only)
FLOWER_USER=admin
FLOWER_PASSWORD=REPLACE_ME_RUN_python3_c_secrets_token_hex_16

# Optional model proxy target
OLLAMA_BASE_URL=http://ollama:11434

# Translation
TRANSLATION_BACKEND=
TRANSLATION_TARGET_LANGUAGE=en

# Scoring
CONVERGENCE_ALERT_THRESHOLD=2.0
CONVERGENCE_BASELINE_DAYS=365

# Features
ENABLE_EO_CHANGE_DETECTION=true
ENABLE_SERVER_SIDE_BYOK_STORAGE=true

# Operational notes:
# - Keep Flower off the public internet.
# - Terminate TLS correctly at the reverse proxy.
# - Do not publish Postgres or Redis ports publicly.
