# ══════════════════════════════════════════════════════════════════════════════
# Echelon — Environment Variables
# Copy to .env and fill in all values before running docker compose up
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Application secrets ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_real_secret

# ── GitHub OAuth (for user authentication) ────────────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
# Callback URL: http://localhost/auth/callback (dev) or https://yourdomain/auth/callback (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Global Fishing Watch API ──────────────────────────────────────────────────
# Register at: https://globalfishingwatch.org/our-apis/
# Free for non-commercial / open-source use
GFW_API_TOKEN=

# ── News APIs (all three feed the same convergence signal) ───────────────────
# NewsData.io — https://newsdata.io (200 credits/day free)
NEWSDATA_API_KEY=
# NewsAPI.org — https://newsapi.org (100 requests/day free)
NEWSAPI_API_KEY=
# GNews.io — https://gnews.io (100 requests/day free)
GNEWS_API_KEY=

# ── NASA FIRMS (active fire / thermal anomaly detection) ─────────────────────
# Register at: https://firms.modaps.eosdis.nasa.gov/api/area/ (free MAP key)
FIRMS_MAP_KEY=

# ── AISStream (real-time AIS vessel tracking) ─────────────────────────────────
# Register at: https://aisstream.io (free, requires GitHub auth)
AISSTREAM_API_KEY=

# ── YouTube Data API (conflict video search) ─────────────────────────────────
# Create at: https://console.cloud.google.com/apis (10k free queries/day)
YOUTUBE_API_KEY=

# ── Resend (email alerts) ─────────────────────────────────────────────────────
# Register at: https://resend.com
# Free tier: 3,000 emails/month
# Must verify a domain you own — add DNS records per Resend dashboard
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── BYOK key encryption (server-side storage, optional) ──────────────────────
# Used to AES-256 encrypt user BYOK Anthropic keys if they opt into server-side storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOK_ENCRYPTION_KEY=

# ── Celery ────────────────────────────────────────────────────────────────────
# These are constructed from other vars in docker-compose.yml
# Set here only if running workers outside Docker
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Flower (internal monitoring) ──────────────────────────────────────────────
# Basic auth for Flower dashboard at /flower/
FLOWER_USER=admin
FLOWER_PASSWORD=change_me

# ── GDELT ────────────────────────────────────────────────────────────────────
# Fully open — no API key required
# Configure ingestion frequency here (minutes)
GDELT_INGEST_INTERVAL_MINUTES=60

# ── Convergence scorer ────────────────────────────────────────────────────────
# Z-score threshold above which alerts are triggered
CONVERGENCE_ALERT_THRESHOLD=2.0
# Baseline window in days (365 recommended — needs 1yr of data to be fully meaningful)
CONVERGENCE_BASELINE_DAYS=365

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable experimental features
ENABLE_EO_CHANGE_DETECTION=true
ENABLE_SERVER_SIDE_BYOK_STORAGE=true
